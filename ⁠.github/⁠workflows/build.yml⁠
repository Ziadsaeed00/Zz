name: Build Tweak
on: [push, pull_request]
jobs:
  build:
    runs-on: ubuntu-latest
    steps:
    - __uses: actions/checkout@v3
    - __name: Prepare Theos
      run: |
        bash -c "$(curl -fsSL https://raw.githubusercontent.com/theos/theos/master/bin/install-theos)"
    - __name: Build Dylib
      run: |
        make package
